config.php

# ---- Local SQLite database (dev only; production uses MySQL) ----
storage/*.sqlite
storage/*.sqlite-journal

# ---- Uploaded media (user content) — keep the folder + its .htaccess only ----
storage/uploads/*
!storage/uploads/.htaccess

